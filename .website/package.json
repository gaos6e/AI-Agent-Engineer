{
  "name": "ai-agent-engineer-site",
  "version": "1.0.0",
  "private": true,
  "description": "Read-only Quartz 5 publishing wrapper for the AI Agent Engineer Obsidian knowledge base.",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10.9.2"
  },
  "scripts": {
    "bootstrap": "node scripts/bootstrap-runtime.mjs",
    "stage": "node scripts/prepare-content.mjs",
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "preview": "node scripts/preview-static.mjs",
    "export:repo": "node scripts/export-public-repository.mjs",
    "scan:repo": "node scripts/scan-public-repository.mjs",
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/validate-site.mjs"
  },
  "dependencies": {
    "gsap": "3.15.0",
    "mermaid": "11.16.0",
    "yaml": "2.9.0"
  }
}
